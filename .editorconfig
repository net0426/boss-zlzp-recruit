# ===========================================
# EditorConfig 配置文件
# ===========================================
# 项目：招聘岗位智能筛选系统
# 统一编辑器的代码风格
# ===========================================

# 所有文件
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python 文件
[*.py]
indent_style = space
indent_size = 4
max_line_length = 120

# YAML 文件
[*.yml]
indent_style = space
indent_size = 2

# JSON 文件
[*.json]
indent_style = space
indent_size = 2

# Markdown 文件
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Shell 脚本
[*.sh]
indent_style = space
indent_size = 2

# Makefile
[Makefile]
indent_style = tab

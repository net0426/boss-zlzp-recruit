# ===========================================
# Python
# ===========================================

# Python 编译文件
__pycache__/
*.py[cod]
*$py.class
*.so

# Python 虚拟环境
venv/
.venv/
ENV/
env/
.env/

# Python 包安装目录
*.egg-info/
dist/
build/
eggs/
*.egg

# PyInstaller
*.manifest
*.spec

# ===========================================
# 配置和敏感文件
# ===========================================

# 环境配置文件（包含密钥和敏感信息）
.env
.env.local
.env.*.local

# 账号凭证文件
*.credential
*.key
*.pem
*.crt
*.key

# ===========================================
# 日志文件
# ===========================================

logs/
*.log
log/

# ===========================================
# 测试和缓存
# ===========================================

.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE 配置（可选保留）
.idea/
.vscode/
*.swp
*.swo
*~

# ===========================================
# 系统文件
# ===========================================

.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini


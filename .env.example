# ===========================================
# 招聘岗位智能筛选系统 - 配置文件模板
# ===========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. 不要上传 .env 文件到 GitHub！
# ===========================================

# ===========================================
# AI 服务配置
# ===========================================

# AI API 地址（支持本地 LLaMA.cpp 或第三方 API）
# 本地示例：http://127.0.0.1:8080/v1/chat/completions
# 第三方示例：https://api.openai.com/v1/chat/completions
AI_API_URL=http://127.0.0.1:8080/v1/chat/completions

# LLaMA.cpp 服务路径（仅本地部署时需要）
# Windows 示例：D:\AI-python\llama.cpp\bin\Release\llama-server.exe
# Linux/macOS 示例：./llama.cpp/build/bin/llama-server
LLAMA_SERVER_PATH=./llama.cpp/bin/Release/llama-server.exe

# 模型文件路径（仅本地部署时需要）
# Windows 示例：D:\AI-python\llama.cpp\models\Qwen2.5-7B-Instruct-Q4_K_M.gguf
# Linux/macOS 示例：./llama.cpp/models/Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLAMA_MODEL_PATH=./llama.cpp/models/Qwen2.5-7B-Instruct-Q4_K_M.gguf

# ===========================================
# 招聘平台配置
# ===========================================

# 目标岗位名称
# 示例：Python开发、软件测试、前端工程师
TARGET_JOB_NAME=软件测试

# 目标工作城市
# 示例：北京、上海、广州、深圳
TARGET_REGION=广州

# BOSS直聘最大投递数量
# 设置每次运行最多投递多少个岗位
BOSS_MAX_JOB=30

# 智联招聘最大投递数量
# 设置每次运行最多投递多少个岗位
ZLZP_MAX_JOB=30

# 工作经验要求（留空表示不限）
# 可选值：
#   - 在校生、应届生、1年、1-3年、3-5年、5-10年、10年以上
#   - 或留空表示经验不限
WORK_EXPERIENCE=

# 学历要求（留空表示不限）
# 可选值：
#   - 初中及以下、中专/中技、高中、大专、本科、硕士、博士
#   - 或留空表示学历不限
DEGREE_REQUIREMENT=
